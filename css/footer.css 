/* ====== FOOTER ====== */
.site-footer {
  background: #fff;
  border-top: 2px solid #FFD6E7;
  padding: 3rem 2rem 1rem;
  margin-top: 3rem;
}
.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
  gap: 2rem;
  padding-bottom: 2rem;
}
.footer-brand p { font-size: 0.9rem; color: #aaa; margin-top: 0.5rem; line-height: 1.6; }
.footer-col h4 { font-weight: 800; color: var(--deep-pink); margin-bottom: 0.8rem; }
.footer-col ul  { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
.footer-col ul a { font-size: 0.9rem; color: #777; transition: color 0.2s; }
.footer-col ul a:hover { color: var(--deep-pink); }

.social-links { display: flex; gap: 0.7rem; flex-wrap: wrap; }
.social-btn {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: #F44E7F;
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.95rem;
  transition: transform 0.2s;
}
.social-btn:hover { transform: scale(1.1); }
.social-btn.tiktok { background: #000; }
.social-btn.fb     { background: #1877F2; }
.social-btn.pin    { background: #E60023; }

.newsletter-form {
  display: flex;
  gap: 0.5rem;
  margin-top: 0.5rem;
}
.newsletter-form input {
  flex: 1;
  border: 2px solid #FFD6E7;
  border-radius: 20px;
  padding: 0.45rem 0.9rem;
  font-family: 'Nunito', sans-serif;
  font-size: 0.85rem;
  outline: none;
}
.newsletter-form input:focus { border-color: var(--pink); }
.newsletter-form button {
  background: var(--deep-pink);
  border: none;
  border-radius: 50%;
  width: 36px; height: 36px;
  color: #fff;
  font-size: 1.1rem;
  cursor: pointer;
  transition: transform 0.2s;
}
.newsletter-form button:hover { transform: scale(1.1); }

.footer-bottom {
  text-align: center;
  padding-top: 1.5rem;
  border-top: 1px solid #FFD6E7;
  font-size: 0.85rem;
  color: #bbb;
}

@media (max-width: 800px) {
  .footer-inner { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 500px) {
  .footer-inner { grid-template-columns: 1fr; }
}