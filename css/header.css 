/* ====== HEADER ====== */
.site-header {
  background: #fff;
  border-bottom: 2px solid #FFD6E7;
  position: sticky;
  top: 0;
  z-index: 1000;
  box-shadow: 0 2px 16px rgba(200,100,150,0.1);
}
.header-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  padding: 0.9rem 2rem;
  gap: 1.5rem;
}
.logo {
  font-family: 'Pacifico', cursive;
  font-size: 1.2rem;
  line-height: 1.2;
  color: var(--deep-pink);
  text-decoration: none;
}
.logo-pink  { color: var(--deep-pink); }
.logo-purple { color: var(--purple); }
.footer-logo { font-size: 1rem; }

.nav-menu {
  display: flex;
  align-items: center;
  gap: 0.2rem;
  margin-left: auto;
}
.nav-link {
  font-weight: 700;
  font-size: 0.95rem;
  color: #6b4f7c;
  padding: 0.45rem 0.9rem;
  border-radius: 20px;
  transition: background 0.2s, color 0.2s;
  text-decoration: none;
}
.nav-link:hover, .nav-link.active {
  color: var(--deep-pink);
  background: #FCE4EC;
}

.btn-support {
  background: linear-gradient(135deg, #F44E7F, #B039D0);
  color: #fff !important;
  font-weight: 800;
  padding: 0.55rem 1.3rem;
  border-radius: 50px;
  font-size: 0.9rem;
  text-decoration: none;
  white-space: nowrap;
  transition: transform 0.2s;
}
.btn-support:hover { transform: scale(1.05); }

.hamburger {
  display: none;
  background: none;
  border: none;
  font-size: 1.7rem;
  color: var(--deep-pink);
  cursor: pointer;
  margin-left: auto;
}

@media (max-width: 850px) {
  .hamburger { display: block; }
  .nav-menu {
    display: none;
    flex-direction: column;
    position: absolute;
    top: 70px; left: 0; right: 0;
    background: #fff;
    border-bottom: 2px solid #FFD6E7;
    padding: 1rem 2rem;
    gap: 0.5rem;
    z-index: 999;
    box-shadow: 0 6px 24px rgba(200,100,150,0.15);
  }
  .nav-menu.open { display: flex; }
  .btn-support { display: none; }
}